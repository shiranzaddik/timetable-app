# --- Google sign-in (server) ---
# OAuth Client ID from https://console.cloud.google.com/apis/credentials
# Auth is disabled when this is empty.
GOOGLE_CLIENT_ID=

# Comma-separated whitelist of specific email addresses allowed to sign in.
# Leave empty (and ALLOWED_DOMAINS empty) to allow anyone with a Google
# account.
ALLOWED_EMAILS=shiranzaddik@gmail.com,someone.else@gmail.com

# Comma-separated whitelist of email domains allowed to sign in. Useful
# when you want "anyone with a Gmail address" (ALLOWED_DOMAINS=gmail.com)
# or "anyone in our company" (ALLOWED_DOMAINS=acme.com). When both
# ALLOWED_EMAILS and ALLOWED_DOMAINS are set, a user is admitted if
# either list matches.
ALLOWED_DOMAINS=

# Random string used to sign session JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Google sign-in (client, injected by Vite at build time) ---
# Must be the SAME value as GOOGLE_CLIENT_ID above.
VITE_GOOGLE_CLIENT_ID=

# --- Postgres connection (server) ---
# Neon (https://neon.tech) or any Postgres instance. Persistence is disabled
# when this is empty; users see the demo data and "Save my data" is hidden.
# Example: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=
